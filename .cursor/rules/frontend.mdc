## Auth Context at Root Layout

Even though authentication is out of scope for v1, the `AuthContext` provider must be mounted at the root layout so it is available globally without refactoring when auth is added.

```tsx
// app/layout.tsx
import { AuthProvider } from "@/context/auth-context";

export default function RootLayout({ children }: { children: React.ReactNode }) {
  return (
    <html lang="en">
      <body>
        <AuthProvider>
          {children}
        </AuthProvider>
      </body>
    </html>
  );
}
```

```tsx
// context/auth-context.tsx
"use client";

import { createContext, useContext, useState, ReactNode } from "react";

interface AuthState {
  token: string | null;
  isAuthenticated: boolean;
  login: (token: string) => void;
  logout: () => void;
}

const AuthContext = createContext<AuthState | null>(null);

export function AuthProvider({ children }: { children: ReactNode }) {
  const [token, setToken] = useState<string | null>(null);

  function login(newToken: string) {
    setToken(newToken); // stored in memory only — see JWT rule below
  }

  function logout() {
    setToken(null);
  }

  return (
    <AuthContext.Provider value={{ token, isAuthenticated: !!token, login, logout }}>
      {children}
    </AuthContext.Provider>
  );
}

export function useAuth(): AuthState {
  const ctx = useContext(AuthContext);
  if (!ctx) throw new Error("useAuth must be used inside AuthProvider");
  return ctx;
}
```

---

## JWT Stored in Memory Only — Never localStorage or Cookies

**JWTs must be stored exclusively in React state (in-memory). No `localStorage`, no `sessionStorage`, no `document.cookie` writes from the frontend.**

- Tokens live in `AuthContext` state and are lost on page refresh — this is intentional for this project's security posture.
- Do not persist tokens across sessions unless explicitly required by a future spec change.
- When attaching tokens to requests, read from context or pass as argument — never read from `window.localStorage`.

```typescript
// ❌ NEVER do this
localStorage.setItem("jwt", token);
const token = localStorage.getItem("jwt");

// ✅ Correct — token lives in AuthContext state only
const { token } = useAuth();
```

```typescript
// lib/api.ts — attach token from memory when needed
export async function getProtectedResource(token: string): Promise<ProtectedData> {
  return apiFetch<ProtectedData>("/api/protected", {
    headers: { Authorization: `Bearer ${token}` },
  });
}
```

